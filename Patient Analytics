<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Patient Analytics Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- Chart.js CDN (self-host in production for security) -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
  body {
    font-family: Arial, sans-serif;
    background: #f4f6f9;
    margin: 0;
    padding: 0;
  }
  .header {
    background: #2563eb;
    color: white;
    padding: 1.5rem;
    text-align: center;
  }
  .container {
    max-width: 1200px;
    margin: 1.5rem auto;
    padding: 1rem;
  }
  .card {
    background: white;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 1.5rem;
  }
  h2 {
    margin-top: 0;
    color: #1f2937;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: .5rem;
  }
</style>
</head>

<body>

<div class="header">
  <h1>Patient Dashboard – EMR Analytics</h1>
</div>

<div class="container">

  <!-- Patient Snapshot -->
  <div class="card">
    <h2>Patient Snapshot</h2>
    <div class="info-row"><strong>Name:</strong> <span id="pName">John Doe</span></div>
    <div class="info-row"><strong>Age:</strong> <span id="pAge">54</span></div>
    <div class="info-row"><strong>Sex:</strong> <span id="pSex">Male</span></div>
    <div class="info-row"><strong>Conditions:</strong> <span id="pCond">Hypertension, Type 2 Diabetes</span></div>
    <div class="info-row"><strong>Medications:</strong> <span id="pMeds">Metformin, Lisinopril</span></div>
  </div>

  <!-- Analytics Grid -->
  <div class="grid">

    <!-- Vitals Trend -->
    <div class="card">
      <h2>Vitals Trend (BP)</h2>
      <canvas id="bpChart"></canvas>
    </div>

    <!-- Lab Distribution -->
    <div class="card">
      <h2>Lab Distribution (A1C)</h2>
      <canvas id="labBox"></canvas>
    </div>

    <!-- Encounter Frequency -->
    <div class="card">
      <h2>Encounters Over Time</h2>
      <canvas id="encChart"></canvas>
    </div>

    <!-- Risk Radar -->
    <div class="card">
      <h2>Risk Profile</h2>
      <canvas id="riskChart"></canvas>
    </div>

  </div>
</div>

